# ----------------------------
# Required
# ----------------------------

# Where your files live on disk. Must be an absolute path in production.
# Default in code if unset: ./data/storage
ORTEGA_STORAGE_ROOT=/path/to/OrtegaPointCommunity

# Where the app stores its metadata SQLite db.
# Default in code if unset: ./data
ORTEGA_DATA_DIR=/path/to/.ortegapoint-community/data

# Bind address.
# Use 0.0.0.0 for Tailscale mode.
# Use 127.0.0.1 for Local-only and Cloudflare Tunnel modes.
HOSTNAME=127.0.0.1

# App port.
PORT=3000

# Max single-file upload size in MB.
# Default in code if unset: 500
# Example high-limit value: 20000
ORTEGA_MAX_UPLOAD_MB=20000

# ----------------------------
# Cloudflare Access
# Public-URL mode only
# Leave blank in Tailscale-only and Local-only modes.
# ----------------------------

# Example: your-team.cloudflareaccess.com
CF_ACCESS_TEAM_DOMAIN=

# Audience value from your Cloudflare Access self-hosted application.
CF_ACCESS_AUD=

# ----------------------------
# Telegram alerting
# Used by scripts/disk-watch.sh
# ----------------------------

# Telegram bot token for disk alerts.
TELEGRAM_BOT_TOKEN=

# Telegram chat ID (yours or a group). Without both this and the token set,
# disk-watch.sh runs in log-only mode (no alerts).
TELEGRAM_CHAT_ID=

# ----------------------------
# Nightly backup
# Used by scripts/backup.sh
# ----------------------------

# Destination directory for backup snapshots.
ORTEGA_BACKUP_DIR=

# Backup retention is currently fixed in scripts/backup.sh.
# The script keeps the last 14 snapshots.
