# Ortega Point Community storage root on disk. The app will create it on first run.
ORTEGA_STORAGE_ROOT=__STORAGE_ROOT__

# Ortega Point Community app data directory. SQLite lives here.
ORTEGA_DATA_DIR=__DATA_DIR__

# Maximum upload size in megabytes.
ORTEGA_MAX_UPLOAD_MB=500

# Bind address for the standalone Next.js server.
# Tailscale mode uses 0.0.0.0, Cloudflare and local-only use 127.0.0.1.
HOSTNAME=__HOSTNAME__

# TCP port for the app.
PORT=__PORT__

# Cloudflare Access team domain, for example:
# team-name.cloudflareaccess.com
# Leave blank for Tailscale-only and local-only installs.
CF_ACCESS_TEAM_DOMAIN=__CF_TEAM__

# Cloudflare Access AUD value from the Access application.
# Leave blank for Tailscale-only and local-only installs.
CF_ACCESS_AUD=__CF_AUD__

# Explicit production runtime.
NODE_ENV=production
